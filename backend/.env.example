# ===========================================
# Axiom AI Concierge Platform - Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# JWT Authentication (REQUIRED)
# Generate a secure random string (min 32 characters)
AXIOM_JWT_SECRET=your-secure-jwt-secret-min-32-chars

# Session Configuration
AXIOM_JWT_EXPIRE_MINUTES=60
AXIOM_COOKIE_SECURE=true  # Set to false only for local development over HTTP

# CORS Configuration (comma-separated list of allowed origins)
AXIOM_ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
AXIOM_RATE_LIMIT=100/minute
AXIOM_AUTH_RATE_LIMIT=5/minute  # Stricter limit for auth endpoints

# OpenRouter API Key (REQUIRED for AI features)
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# Tavily Search API Key (REQUIRED for web search features)
# Get your key from: https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-api-key

# Inika API Key (REQUIRED)
INIKA_API_KEY=your-inika-api-key

# Weather Service (optional)
# Leave empty to use default Coorg coordinates
WEATHER_API_KEY=
WEATHER_LAT=12.3375
WEATHER_LON=75.8061

# Database (optional overrides)
# DB_PATH=./data/tenants

# Debug Mode (set to false in production)
DEBUG=false
